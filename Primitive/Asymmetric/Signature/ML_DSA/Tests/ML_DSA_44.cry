deconstruct = I2_back == I2 where
    (rho, K, tr, s1, s2, t0) = skDecode expected_sk
    (rho_pk, t1) = pkDecode expected_pk

    s1_q = [map fromInteger s1i | s1i <- s1] : [4]Rq
    s2_q = [map fromInteger s2i | s2i <- s2] : [4]Rq

    A_hat = (ExpandA rho)

    // Compute each intermediate step going backward from the expected result.
    I4_back = reversePower2Round t1 t0
    I3_back = I4_back - s2_q
    I2_back = NTT_Vec I3_back
    // Inverting matrix multiplication is too hard here.

    // Compute each intermediate step going forward.
    I1 = NTT_Vec s1_q
    I2 = A_hat ∘∘ I1
    I3 = NTTInv_Vec I2
    I4 = I3 + s2_q




tryDetKAT xi expected_pk expected_sk = keygenWorks where
    (pk, sk) = KeyGen_internal xi
    keygenWorks = (pk == expected_pk) && (sk == expected_sk)

    //verifyWorks = Verify_internal`{16 * 8} expected_pk msg expected_sm




